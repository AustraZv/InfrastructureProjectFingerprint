{
  "manifest_version": 2,
  "name": "Privacy Intelligence Scanner",
  "version": "0.1",
  "description": "Real-time third-party tracker detection.",
  "permissions": [
    "<all_urls>",
    "webRequest",
    "webRequestBlocking",
    "tabs",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Privacy Scanner"
  }
}